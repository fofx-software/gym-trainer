TELEGRAM_BOT_TOKEN=replace-with-token-from-botfather
OPENAI_API_KEY=replace-with-openai-api-key
# Recommended: send /whoami to the bot, then place the returned number here.
ALLOWED_TELEGRAM_USER_ID=
OPENAI_MODEL=gpt-5-mini
GOOGLE_CLOUD_PROJECT=gym-trainer-502823
FIRESTORE_DATABASE=(default)
# Leave blank for local polling. Set to the Cloud Run HTTPS service URL in production.
WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-secret
PORT=8080
